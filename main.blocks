<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="3mc})QAe}moxlB^So`}^" x="0" y="0"><statement name="HANDLER"><block type="typescript_statement" id="mBRhu_-@KFR:^stRRA$5"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace MrJeonBlocks {" line1="" line2="    /**" line3="     * Lights up a specific number of LEDs in order." line4="     * @param num the number of LEDs to turn on, eg: 5" line5="     */" line6="    //% block=&quot;show number LED $num&quot;" line7="    //% num.min=0 num.max=25" line8="    export function showNumberLED(num: number): void {" line9="        basic.clearScreen()" line10="        for (let index2 = 0; index2 &lt; num; index2++) {" line11="            led.plot(index2 % 5, Math.floor(index2 / 5))" line12="        }" line13="    }" line14="" line15="}" numlines="16"></mutation></block></statement></block></xml>